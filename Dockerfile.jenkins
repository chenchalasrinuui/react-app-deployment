FROM jenkins/jenkins:lts

USER root

# Install Node.js (LTS) and lftp for the build + FTP deploy stages
RUN apt-get update && \
    apt-get install -y curl gnupg lftp && \
    curl -fsSL https://deb.nodesource.com/setup_20.x | bash - && \
    apt-get install -y nodejs && \
    rm -rf /var/lib/apt/lists/*

USER jenkins